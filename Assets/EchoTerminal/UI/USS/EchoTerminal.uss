:root {
    /* Backgrounds — Islands Dark Beta (ManyIslandsDark) */
    --bg-base: #191A1C;
    --bg-elevated: #26282C;
    --bg-toolbar: #26282C;
    --bg-input: #26272b;
    --bg-log: #1F2024;
    --bg-log-alt: #191A1C;
    --bg-popup: #26282C;

    /* Borders */
    --border-window: #5F6269;
    --border-subtle: #33353B;
    --border-default: #393B40;
    --border-dark: #26282C;

    /* Text */
    --text-primary: #BCBEC4;
    --text-muted: #7A7E85;
    --text-inactive: #9FA2A8;
    --text-bright: #D1D3D9;

    /* Interactive */
    --interactive-hover: rgba(255, 255, 255, 0.09);
    --interactive-active: rgba(255, 255, 255, 0.16);

    /* Accents */
    --accent-focus: #2A4371;
    --accent-copy: #3A7D44;
    --accent-copy-text: #A8E6B0;
    --close-default: #FF5F57;
    --close-hover: #FF3B30;

    /* Scrollbar */
    --scrollbar-thumb: rgba(128, 128, 128, 0.35);
    --scrollbar-thumb-hover: rgba(128, 128, 128, 0.55);
    --scrollbar-thumb-active: rgba(128, 128, 128, 0.75);
}

.terminal-container {
    background-color: var(--bg-base);
    flex-grow: 1;
    overflow: hidden;
}

.terminal-toolbar {
    flex-direction: row;
    align-items: center;
    background-color: var(--bg-toolbar);
    padding: 2px 4px;
    border-bottom-width: 1px;
    border-bottom-color: var(--border-dark);
    min-height: 22px;
}

.terminal-toolbar-button {
    background-color: #2E3035;
    border-width: 1px;
    border-top-color: #3E4148;
    border-left-color: #3E4148;
    border-bottom-color: #111213;
    border-right-color: #111213;
    border-radius: 3px;
    padding: 2px 8px;
    margin: 0 2px;
    color: var(--text-primary);
    font-size: 11px;
    -unity-text-align: middle-center;
    translate: 0 0;
}

.terminal-toolbar-button:hover {
    background-color: #33353B;
    color: var(--text-bright);
}

.terminal-toolbar-button:active {
    background-color: #1C1D20;
    border-top-color: #111213;
    border-left-color: #111213;
    border-bottom-color: #2E3035;
    border-right-color: #2E3035;
    color: var(--text-muted);
    translate: 0 1px;
}

.terminal-toolbar-toggle {
    background-color: #1C1D20;
    border-width: 1px;
    border-top-color: #111213;
    border-left-color: #111213;
    border-bottom-color: #2E3035;
    border-right-color: #2E3035;
    border-radius: 3px;
    padding: 2px 8px;
    margin: 0 2px;
    color: var(--text-muted);
    font-size: 11px;
    -unity-text-align: middle-center;
    translate: 0 1px;
}

.terminal-toolbar-toggle:hover {
    background-color: #222326;
    color: var(--text-inactive);
}

.terminal-toolbar-toggle--active {
    background-color: #2E3035;
    border-top-color: #3E4148;
    border-left-color: #3E4148;
    border-bottom-color: #111213;
    border-right-color: #111213;
    color: var(--text-primary);
    translate: 0 0;
}

.terminal-toolbar-toggle--active:hover {
    background-color: #33353B;
    color: var(--text-bright);
}

.terminal-filter-button {
    margin-left: 2px;
}

.terminal-toolbar-separator {
    width: 1px;
    background-color: var(--interactive-hover);
    margin: 2px 6px;
    align-self: stretch;
}

.terminal-log {
    flex-grow: 1;
    min-height: 0;
    padding: 0;
    background-color: var(--bg-log);
}

.terminal-log #unity-content-container {
    padding: 0;
}

.terminal-entry {
    font-size: 12px;
    color: var(--text-primary);
    padding: 2px 8px;
    margin: 0;
    white-space: normal;
    -unity-text-align: upper-left;
    flex-direction: row;
    -unity-font-definition: url('../../Fonts/JetBrainsMono-SemiBold.ttf');
}

.terminal-entry--odd {
    background-color: var(--bg-log);
}

.terminal-entry--even {
    background-color: var(--bg-log-alt);
}

.terminal-timestamp {
    display: none;
    color: var(--text-muted);
    font-size: 11px;
    -unity-text-align: upper-left;
    padding: 0;
    margin: 0;
    margin-right: 4px;
}

.timestamps-visible .terminal-timestamp {
    display: flex;
}

.terminal-message {
    flex-grow: 1;
    white-space: normal;
    padding: 0;
    margin: 0;
}

.terminal-input-row {
    flex-direction: row;
    align-items: center;
    background-color: var(--bg-input);
    border-top-width: 1px;
    border-top-color: var(--bg-base);
    flex-shrink: 0;
}

.terminal-prompt {
    width: 14px;
    height: 14px;
    margin: 0 2px 0 8px;
    flex-shrink: 0;
    background-image: url('../Icons/prompt-arrow.svg');
    -unity-background-scale-mode: scale-to-fit;
}

.terminal-input {
    flex-grow: 1;
    margin: 0;
    background-color: transparent;
    border-width: 0;
}

.terminal-input > .unity-text-field__input {
    font-size: 14px;
    background-color: transparent;
    border-width: 0;
    color: var(--text-primary);
    padding: 5px 6px;
    -unity-font-definition: url('../../Fonts/JetBrainsMono-SemiBold.ttf');
    white-space: pre;
    --unity-cursor-color: var(--text-bright);
}

.terminal-input:focus > .unity-text-field__input {
    background-color: transparent;
}

.terminal-highlight {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    font-size: 14px;
    padding: 5px 6px;
    margin: 0;
    overflow: hidden;
    white-space: pre;
    -unity-font-definition: url('../../Fonts/JetBrainsMono-SemiBold.ttf');
}

.terminal-suggestion-popup {
    position: absolute;
    bottom: 100%;
    left: 0;
    right: 0;
    background-color: var(--bg-popup);
    border-width: 1px;
    border-color: var(--border-default);
    -unity-font-definition: url('../../Fonts/JetBrainsMono-SemiBold.ttf');
}

.terminal-suggestion-list {
    max-height: 200px;
}

.terminal-suggestion-list > #unity-content-container {
    padding: 0;
}

.terminal-suggestion-list .unity-scroller--vertical {
    width: 8px;
    background-color: transparent;
}

.terminal-suggestion-list .unity-scroller--vertical .unity-base-slider {
    flex-grow: 1;
    margin: 0;
    padding: 0;
    min-width: 0;
    min-height: 0;
}

.terminal-suggestion-list .unity-scroller--vertical .unity-base-slider__tracker {
    background-color: transparent;
    border-width: 0;
    margin: 0;
    padding: 0;
}

.terminal-suggestion-list .unity-scroller--vertical .unity-base-slider__drag-container {
    left: 0;
    right: 0;
    margin: 0;
    padding: 0;
}

.terminal-suggestion-list .unity-scroller--vertical .unity-base-slider__dragger {
    background-color: var(--scrollbar-thumb);
    border-width: 0;
    border-radius: 4px;
    left: 0;
    right: 0;
    width: 100%;
    margin: 0;
    padding: 0;
}

.terminal-suggestion-list .unity-scroller--vertical .unity-base-slider__dragger:hover {
    background-color: var(--scrollbar-thumb-hover);
}

.terminal-suggestion-list .unity-scroller--vertical .unity-base-slider__dragger:active {
    background-color: var(--scrollbar-thumb-active);
}

.terminal-suggestion-list .unity-repeat-button {
    display: none;
    width: 0;
    height: 0;
}

.terminal-suggestion-item {
    font-size: 12px;
    color: var(--text-primary);
    padding: 2px 8px;
}

.terminal-suggestion-item--selected {
    background-color: var(--accent-focus);
    color: var(--text-bright);
}

.terminal-copy-toast {
    position: absolute;
    top: 26px;
    right: 8px;
    background-color: var(--bg-elevated);
    border-width: 1px;
    border-color: var(--border-default);
    border-radius: 4px;
    color: var(--text-bright);
    font-size: 11px;
    padding: 4px 10px;
    -unity-text-align: middle-center;
}

#copy-button:active {
    background-color: var(--accent-copy);
    color: var(--accent-copy-text);
}

.terminal-hint-label {
    font-size: 12px;
    color: var(--text-muted);
    padding: 4px 8px;
    -unity-font-style: italic;
    border-top-width: 1px;
    border-top-color: var(--border-default);
}

.filter-hide-log .terminal-entry--log         { display: none; }
.filter-hide-warning .terminal-entry--warning { display: none; }
.filter-hide-error .terminal-entry--error     { display: none; }
.filter-hide-command .terminal-entry--command { display: none; }

.terminal-log .unity-scroller--vertical {
    width: 8px;
    background-color: transparent;
}

.terminal-log .unity-scroller--vertical .unity-base-slider {
    flex-grow: 1;
    margin: 0;
    padding: 0;
    min-width: 0;
    min-height: 0;
}

.terminal-log .unity-scroller--vertical .unity-base-slider__tracker {
    background-color: transparent;
    border-width: 0;
    margin: 0;
    padding: 0;
}

.terminal-log .unity-scroller--vertical .unity-base-slider__drag-container {
    left: 0;
    right: 0;
    margin: 0;
    padding: 0;
}

.terminal-log .unity-scroller--vertical .unity-base-slider__dragger {
    background-color: var(--scrollbar-thumb);
    border-width: 0;
    border-radius: 4px;
    left: 0;
    right: 0;
    width: 100%;
    margin: 0;
    padding: 0;
}

.terminal-log .unity-scroller--vertical .unity-base-slider__dragger:hover {
    background-color: var(--scrollbar-thumb-hover);
}

.terminal-log .unity-scroller--vertical .unity-base-slider__dragger:active {
    background-color: var(--scrollbar-thumb-active);
}

.terminal-log .unity-repeat-button {
    display: none;
    width: 0;
    height: 0;
}
